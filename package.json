{
  "name": "system-managment",
  "productName": "Zagros System",
  "version": "0.1.0",
  "description": "System Management — Selling, Warehouse, Settings (Windows 10-11)",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "build:web": "vite build",
    "deploy:cf": "wrangler deploy",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "start": "electron .",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "windows",
    "system-management",
    "pos",
    "warehouse"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "out",
    "package.json"
  ],
  "build": {
    "appId": "com.zagros.system",
    "productName": "Zagros System",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "compression": "maximum"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zagros System"
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0",
    "wrangler": "^3.99.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "jsbarcode": "^3.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
